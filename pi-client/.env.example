# AWS IoT Core endpoint created for this project.
# Check/update with: aws iot describe-endpoint --endpoint-type iot:Data-ATS --region ap-northeast-2
AWS_IOT_ENDPOINT=a1s06ji5k8zr3p-ats.iot.ap-northeast-2.amazonaws.com

# Device identity. Must match the topic contract health/sensor/{DEVICE_ID}/environment.
DEVICE_ID=rpi_001
MQTT_CLIENT_ID=rpi_001

# X.509 files copied onto the Raspberry Pi. Never commit real cert/private-key files.
AWS_IOT_ROOT_CA=certs/AmazonRootCA1.pem
AWS_IOT_CERT=certs/rpi_001.pem.crt
AWS_IOT_PRIVATE_KEY=certs/rpi_001.private.pem.key

# Publish every 30 seconds with QoS 1 so the IoT Rule path is easier to verify.
SAMPLE_INTERVAL_SEC=30
PUBLISH_QOS=1
AWS_IOT_OPERATION_TIMEOUT_SEC=10

# Laptop/demo mode: true = all values random.
# Raspberry Pi mode: false = DHT11 real values + ZPH01/SGP30 random substitute values.
MOCK_SENSOR=false

# DHT11: DATA->GPIO4/physical pin 7, 10k pull-up to 3.3V.
DHT11_PIN=D4
DHT11_USE_PULSEIO=false
