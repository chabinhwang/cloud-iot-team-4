# API Gateway endpoint created for this project.
# Current deployed endpoint:
API_BASE_URL=https://2en76mdnw1.execute-api.ap-northeast-2.amazonaws.com

# Device identity saved as DEVICE#{DEVICE_ID} in DynamoDB.
DEVICE_ID=rpi_001

# Publish every 30 seconds to POST /measurements/environment.
SAMPLE_INTERVAL_SEC=30
HTTP_TIMEOUT_SEC=10

# Laptop/demo mode: true = all values random.
# Raspberry Pi mode: false = DHT11 real values + ZPH01/SGP30 random substitute values.
MOCK_SENSOR=false

# DHT11: DATA->GPIO4/physical pin 7, 10k pull-up to 3.3V.
DHT11_PIN=D4
DHT11_USE_PULSEIO=false
