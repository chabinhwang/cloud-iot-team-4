# 서버
PORT=3000

# MQTT
EMBEDDED_BROKER=true
MQTT_PORT=1883
MQTT_URL=mqtt://localhost:1883

# Mock 토글
USE_MOCK_SENSOR=true
USE_MOCK_FITBIT=true
USE_MOCK_WEATHER=true
USE_MOCK_DISCORD=true

# Mock 주기 (ms)
MOCK_SENSOR_INTERVAL_MS=5000

# Scheduler
SCHEDULER_ENABLED=true
MORNING_CRON=0 7 * * *
DEFAULT_TIMEZONE=Asia/Seoul

# 기본 식별자 (Mock/개발용)
DEFAULT_USER_ID=user_001
DEFAULT_DEVICE_ID=rpi_001

# Fitbit OAuth
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:3000/auth/fitbit/callback

# 외부 API 키
AIRKOREA_API_KEY=
KMA_API_KEY=

# Discord Webhook
DISCORD_WEBHOOK_URL=
